# LedgerVault root ignore

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.keystore
*.jks
*.mobileprovision
*.p12
frontend/android/key.properties
frontend/android/*.keystore
frontend/android/*.jks

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# Node/backend
node_modules/
backend/node_modules/
backend/dist/
backend/build/
backend/coverage/
backend/uploads/
backend/.env
backend/.env.*
!backend/.env.example

# Flutter/frontend
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/coverage/
frontend/.env
frontend/.env.*
!frontend/.env.example

# Flutter generated platform build output
frontend/android/.gradle/
frontend/android/app/build/
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/.last_build_id
frontend/linux/flutter/ephemeral/
frontend/macos/Flutter/ephemeral/
frontend/windows/flutter/ephemeral/
frontend/web/flutter_service_worker.js

# Generated archives and local reports
*.zip
*.tar
*.tar.gz
*.7z
*.tmp
*.bak
